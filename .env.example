# Secret Key — gere uma unica e forte:
# python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=COLE_SUA_SECRET_KEY_AQUI

# Database (padrao: SQLite local)
# PostgreSQL exemplo: postgresql://user:pass@localhost:5432/pinkurban
DATABASE_URL=sqlite:///pink_urban.db

# Cookie seguro — mude para true quando tiver HTTPS
SESSION_COOKIE_SECURE=false

# Forcar HTTPS (ative em producao com HTTPS ativo)
FORCE_HTTPS=false

# Rate limiting storage (memory:// para desenvolvimento, redis:// para producao com muitos usuarios)
RATELIMIT_STORAGE_URL=memory://

# Modo debug — NAO ative em producao
FLASK_DEBUG=false
